<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=<device-width>, initial-scale=1.0" />
    <title>Document</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

    <style>
    
    td{
      padding-right: 2rem;
    }
    .button {
      display: inline-block;
      width: 30px;
      height: 30px;
      background-color: crimson;
      text-decoration: none;
      text-align: center;
      color: white;
      font-weight: bold;
    }
    </style>
  
  
</head>
    <body>
    <div class="card">
        <div class="card-header">Category data</div>
        <div class="card-body">
          <div class="table-responsive">
            <table id="myTable">
              <thead>
                <tr>
                  <td>Id</td>
                  <td>Category-Name</td>
                </tr>
            </thead>
            <tbody>
              <%data.data.forEach((element)=>{%>
                <%console.log(element.id)%>
                <tr>
                    <td><%-element.id%></td>
                    <td><%-element.name%></td>
                    <td><a href="/category/data/<%-element.id%>">Edit</a></td>
                    <td><input type="button" onclick="deleteData('<%= element.id %>')"value="Delete" ></td>
                </tr>
                <%})%>
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <% for(let i=1;i<=data.total_table;i++) {%>
          <a class="button" href="/category/category-list/<%= i %>"><%=i %></a>
        <% } %>
      </div>
    </div>
  </body>
  </html>
  </body>
  <script>
    
    async function deleteData(id) {
      if(confirm("Are you sure you want to delete the data?") == true ){
        let qry_str = await fetch(`/category/delete/${id}`,{
          method:"PATCH",
          headers:{
            'Content-type':'application/json',
          }
        });
        window.location.reload()
        return true;
      }
      else{
        return false;
      }
    }
  </script>
  </html>
  
