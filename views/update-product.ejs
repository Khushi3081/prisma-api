<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Product</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
  </head>
  <style>
    .container {
      width: 1440px;
      margin: auto;
    }
  </style>
  <body>
    <div class="container">
      <form action="">
        <div class="mb-3">
          <label for="formGroupExampleInput" class="form-label"
            >Edit Product</label
          >

          <div>
            <select class="form-select" aria-label="Default select example" name="c_id" id="category" onchange="addSubCategory()">
              <option selected>Select One Category</option>
              <% for(let i=0;i<category.length;i++) {%>
              <option value="<%=category[i].id%>" <% if(category[i].name == data[0].subCategory.candidate.name) {%> Selected <% } %> ><%=category[i].name%></option>
            <% } %>
          </select>
          </div><br>
          
          <div>
            <select class="form-select" aria-label="Default select example" name="sub_id" id="subcategory"> 

              <% category.forEach(d => { %>
                <% d.subCats.forEach(s => { %>
                  <% console.log(s) %>
                    <option value="<%=s.id%>"<% if(s.name == data[0].subCategory.name) {%> Selected <% } %> ><%=s.name%></option>
                  <% });%>
                <% });%>
            </select>
            </div><br>
            <input
            type="text"
            id="p_id"
            name="id"
            value="<%= data[0].id %>"
            hidden
          />
          <div>
          <input
            type="text"
            class="form-control",
            name = "productname"
            id="formGroupExampleInput"
            value="<%= data[0].name%>"
            placeholder="Product Name"
          /><br>
          <input
            type="text"
            class="form-control",
            name = "productprice"
            id="formGroupExampleInput"
            value="<%= data[0].price %>"
            placeholder="Product Price"
          /><br>
          <input
            type="text"
            class="form-control",
            name = "productquntity"
            id="formGroupExampleInput"
            value="<%= data[0].quantity %>"
            placeholder="Product Quantity"
          />
          
          </div>
        </div>
        <input type="button" class="btn btn-primary" value="Submit" onclick="validate()"/>
      </form>
    </div>
  </body>
  <script
    src="https://code.jquery.com/jquery-3.5.1.slim.min.js"
    integrity="sha384-DfXdz2htPH0lsSSs5nCTpuj/zy4C+OGpamoFVy38MVBnE+IbbVYUew+OrCXaRkfj"
    crossorigin="anonymous"
  ></script>
  <script
    src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"
    integrity="sha384-9/reFTGAW83EW2RDu2S0VKaIzap3H66lZH81PoYlFhbGU+6BZp6G7niu735Sk7lN"
    crossorigin="anonymous"
  ></script>


  <script>
    async function addSubCategory() {
      const category_id = document.getElementById("category").value;
      // console.log(category_id);
      const qry_string = await fetch(`/product/sub/${category_id}`);
      // console.log(qry_string);
      const answer = await qry_string.json()
      updateSubCategory(answer)
    }
    async function updateSubCategory(answer){
      // console.log(answer);
      const sc_dropdown = await document.getElementById("subcategory");
      sc_dropdown.innerHTML = "";

      for(let i=0;i<answer.subcategory.length;i++) {
        const option = await document.createElement('option');
        option.value = answer.subcategory[i].id;
        option.text = answer.subcategory[i].name;
        sc_dropdown.appendChild(option);
      }
    }
  </script>
  <script>
    async function validate() {
      let id = document.getElementById('p_id').value;
      let c_id = document.getElementsByName('c_id')[0].value;
      let sub_id = document.getElementById('subcategory').value;
      let name = document.getElementsByName('productname')[0].value;
      let price= document.getElementsByName('productprice')[0].value;
      let quantity= document.getElementsByName('productquntity')[0].value;
      // console.log(c_id);
      let qry_str = await fetch(`http://localhost:5000/product/update/${id}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ c_id,sub_id,name,price,quantity }),
      }).then(window.location.href = '/product/product-list')
     
    }
  </script>
</html>
