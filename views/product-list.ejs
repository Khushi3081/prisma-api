<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=<device-width>, initial-scale=1.0" />
  <title>Document</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.1.3/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.12.1/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <style>
    .button {
        display: inline-block;
        width: 30px;
        height: 30px;
        background-color: crimson;
        text-decoration: none;
        text-align: center;
        color: white;
        font-weight: bold;
    }
    td{
      padding-right: 2rem;
    }
  </style>
</head>

<body>
  <div class="card">
    <div class="card-header">Product data</div>
    <div class="card-body">
      <div class="table-responsive">
        <table id="myTable">
          <thead>
            <tr>
              <td>Id</td>
              <td>Category-Name</td>
              <td>Sub-category-Name</td>
              <td>Product-Name</td>
              <td>Product-price</td>
              <td>Product-Quantity</td>

            </tr>
          </thead>
          <tbody>
            <%data.data.forEach((e)=>{%>
              <tr>
                <td><%-e.id%></td>
                <td><%-e.subCategory.candidate.name%></td>
                <td><%-e.subCategory.name%></td>
                <td><%-e.name%></td>
                <td><%-e.price%></td>
                <td><%-e.quantity%></td>
                <td><a href="/product/<%-e.id%>">Edit</a></td>
                <td><input type="button" onclick="deleteData('<%= e.id %>')"value="Delete" ></td>

              </tr>
                  <%})%>
          </tbody>

        </table>
      </div>
    </div>
    <div>
        <% for(let i=1;i<=data.total_table;i++) {%>
          <a class="button" href="/product/product-list/<%= i %>"><%=i %></a>
        <% } %>
    </div>
  </div>
</body>

</html>
</body>
<script>
  async function deleteData(id) {
    if(confirm("Are you sure you want to delete the data?") == true ){
      let qry_str = await fetch(`/product/delete/${id}`,{
        method:"PATCH",
        headers:{
          'Content-type':'application/json',
        }
      });
      window.location.reload()
      return true;
    }
    else{
      return false;
    }
  }
</script>
</html>